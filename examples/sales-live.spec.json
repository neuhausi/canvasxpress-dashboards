{
  "id": "sales-live",
  "title": "Sales (live from database)",
  "version": 1,
  "broadcastGroup": "sales-live",
  "layout": {
    "cols": 12,
    "rowHeight": 130,
    "items": [
      { "panel": "revenue-bar", "x": 0, "y": 0, "w": 6, "h": 3 },
      { "panel": "region-pie",  "x": 6, "y": 0, "w": 6, "h": 3 }
    ]
  },
  "data": {
    "sales": {
      "kind": "connector",
      "url": "/api/data?source=sales",
      "ttl": 60000,
      "refresh": 300
    }
  },
  "panels": {
    "revenue-bar": {
      "title": "Revenue by Region",
      "dataRef": "sales",
      "config": { "graphType": "Bar", "title": false }
    },
    "region-pie": {
      "title": "Share by Region",
      "dataRef": "sales",
      "config": { "graphType": "Pie", "title": false }
    }
  },
  "controls": [
    { "kind": "table", "dataRef": "sales", "title": "Sales Table" }
  ]
}
