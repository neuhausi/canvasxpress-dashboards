{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://canvasxpress.org/schema/dashboard.schema.json",
  "title": "CanvasXpress Dashboard Spec",
  "description": "Declarative spec describing panels, layout, and data bindings for a CanvasXpress dashboard.",
  "type": "object",
  "required": ["id", "layout", "panels"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable dashboard identifier. Defaults the broadcast group.",
      "minLength": 1
    },
    "title": { "type": "string" },
    "version": { "type": "integer", "minimum": 1, "default": 1 },
    "broadcastGroup": {
      "type": "string",
      "description": "Coordination domain isolating this dashboard's panels. Defaults to id."
    },
    "theme": {
      "type": "string",
      "enum": ["light", "dark", "auto"],
      "default": "auto"
    },
    "background": {
      "type": "string",
      "description": "CSS color applied to the dashboard container background."
    },
    "backgroundImage": {
      "type": "string",
      "description": "Background image URL or data URI (rendered cover/centered behind the panels)."
    },
    "canvasInset": {
      "type": "number",
      "minimum": 0,
      "description": "Margin in px left around each panel's CanvasXpress graph."
    },
    "width": {
      "type": ["number", "string"],
      "description": "Explicit dashboard width (number = px, or any CSS length). Unset = fill parent."
    },
    "height": {
      "type": ["number", "string"],
      "description": "Explicit dashboard height (number = px, or any CSS length). Unset = content height."
    },
    "layout": {
      "type": "object",
      "required": ["items"],
      "additionalProperties": true,
      "properties": {
        "cols": { "type": "integer", "minimum": 1, "default": 12 },
        "rowHeight": { "type": "number", "minimum": 1, "default": 120 },
        "gap": { "type": "number", "minimum": 0, "default": 12 },
        "items": {
          "type": "array",
          "items": { "$ref": "#/definitions/layoutItem" }
        }
      }
    },
    "data": {
      "type": "object",
      "description": "Named, reusable data sources referenced by panels via dataRef.",
      "additionalProperties": { "$ref": "#/definitions/dataSource" }
    },
    "panels": {
      "type": "object",
      "description": "Panel definitions keyed by panel id.",
      "additionalProperties": { "$ref": "#/definitions/panel" }
    },
    "controls": {
      "type": "array",
      "items": { "$ref": "#/definitions/control" }
    }
  },
  "definitions": {
    "layoutItem": {
      "type": "object",
      "required": ["panel", "x", "y", "w", "h"],
      "additionalProperties": true,
      "properties": {
        "panel": { "type": "string" },
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "w": { "type": "integer", "minimum": 1 },
        "h": { "type": "integer", "minimum": 1 }
      }
    },
    "dataSource": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": true,
      "properties": {
        "kind": { "type": "string", "enum": ["inline", "connector", "dataset"] },
        "value": { "type": "object" },
        "id": {
          "type": "string",
          "description": "Dataset id (kind:dataset). Resolved to GET /api/datasets/{id} with credentials (cookie auth). Keeps specs path- and credential-free."
        },
        "store": {
          "type": "string",
          "description": "Optional named dataset store to resolve the id against (server-configured; Phase 5.2)."
        },
        "url": {
          "type": "string",
          "description": "Connector endpoint, e.g. /api/data?source=sales, or a signed dataset URL. Fetched with credentials (cookie auth)."
        },
        "ttl": {
          "type": "number",
          "minimum": 0,
          "description": "Cache lifetime in ms for this connector source (0 = no cross-render caching)."
        },
        "refresh": {
          "type": "number",
          "minimum": 0,
          "description": "Poll interval in seconds; refetches and live-updates bound panels."
        },
        "headers": {
          "type": "object",
          "description": "Optional extra request headers for the connector fetch."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "inline" } } },
          "then": { "required": ["value"] }
        },
        {
          "if": { "properties": { "kind": { "const": "connector" } } },
          "then": { "required": ["url"] }
        },
        {
          "if": { "properties": { "kind": { "const": "dataset" } } },
          "then": { "required": ["id"] }
        }
      ]
    },
    "panel": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string" },
        "dataRef": { "type": "string" },
        "data": { "type": "object" },
        "config": { "type": "object" },
        "measures": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Numeric variable names to plot (projects the source to these columns). Empty/absent = all variables."
        },
        "events": { "type": "object" },
        "broadcast": { "type": "boolean" }
      }
    },
    "control": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": true,
      "properties": {
        "kind": { "type": "string", "enum": ["filter", "table"] },
        "dataRef": { "type": "string" },
        "title": { "type": "string" },
        "config": { "type": "object" }
      }
    }
  }
}
